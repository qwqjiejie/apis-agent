# LLM 配置
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# 多模态视觉模型（图片识别），设为空字符串则禁用
VISION_MODEL=qwen-vl-plus

# Tavily 搜索配置
TAVILY_API_KEY=tvly-your-tavily-key-here

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=INFO

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=apis

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=123456

# MinIO 配置
MINIO_HOST=
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=apis
UPLOAD_DIR=uploads

# Milvus 向量数据库配置
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASS=Milvus
MILVUS_DB=apis

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_USER_PER_MIN=60
RATE_LIMIT_IP_PER_MIN=300
RATE_LIMIT_WINDOW_SEC=60

# Langfuse 追踪配置（留空则禁用）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Embedding 配置
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
